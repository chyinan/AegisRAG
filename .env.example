APP_ENV=local
LOG_LEVEL=INFO
ENABLE_DEV_AUTH_HEADERS=false
JWT_SECRET=<replace_with_jwt_secret_at_least_32_bytes>
JWT_ALGORITHM=HS256
JWT_ISSUER=<optional_jwt_issuer>
JWT_AUDIENCE=<optional_jwt_audience>
OPENWEBUI_SERVICE_TOKEN_HASHES_JSON=[{"token_sha256":"<sha256_of_openwebui_provider_api_key>","user_id":"openwebui-service","tenant_id":"tenant-local","roles":["openwebui"],"department":"platform","permissions":["document:read","retrieval:query"]}]
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENWEBUI_PORT=3000
OPENWEBUI_OPENAI_API_BASE_URL=http://api:8000/v1
OPENWEBUI_PROVIDER_API_KEY=<replace_with_local_openwebui_provider_key>
OPENWEBUI_SECRET_KEY=<replace_with_local_openwebui_webui_secret_key>
POSTGRES_USER=rag_app
POSTGRES_PASSWORD=<replace_with_local_postgres_password>
POSTGRES_DB=rag_app
DATABASE_URL=postgresql+asyncpg://rag_app:<replace_with_local_postgres_password>@postgres:5432/rag_app
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<replace_with_minio_access_key>
MINIO_SECRET_KEY=<replace_with_minio_secret_key>
MINIO_BUCKET=documents
MINIO_DOCUMENT_PREFIX=raw-documents
UPLOAD_MAX_BYTES=26214400
INGESTION_QUEUE_NAME=ingestion
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=fake-embedding
EMBEDDING_DIM=8
EMBEDDING_TIMEOUT_SECONDS=10
EMBEDDING_RETRY_BUDGET=2
EMBEDDING_QUEUE_NAME=embedding
VECTOR_STORE_TYPE=pgvector
VECTOR_INDEX_DIM=8
VECTOR_DISTANCE_METRIC=cosine
PGVECTOR_INDEX_TYPE=hnsw
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
WORKER_QUEUE_NAME=ingestion
READINESS_TIMEOUT_SECONDS=2
LLM_PROVIDER=fake
LLM_MODEL=fake-llm
LLM_TIMEOUT_SECONDS=10
LLM_RETRY_BUDGET=2
LLM_FAKE_RESPONSE_TEXT=Fake LLM response.
TOOL_DEFAULT_TIMEOUT_SECONDS=5
TOOL_DEFAULT_RATE_LIMIT_MAX_CALLS=30
TOOL_DEFAULT_RATE_LIMIT_WINDOW_SECONDS=60
FILE_READER_ALLOWLIST_ROOTS=docs
FILE_READER_MAX_FILE_BYTES=32768
FILE_READER_MAX_RETURN_BYTES=4096
AGENT_DEFAULT_MAX_STEPS=8
AGENT_DEFAULT_MAX_TOOL_CALLS=5
AGENT_DEFAULT_TIMEOUT_SECONDS=30
AGENT_REPEATED_ACTION_THRESHOLD=3
OPENAI_API_KEY=<replace_with_secret>
QWEN_API_KEY=<replace_with_secret>
DEEPSEEK_API_KEY=<replace_with_secret>
