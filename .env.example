APP_ENV=local
LOG_LEVEL=INFO
POSTGRES_USER=rag_app
POSTGRES_PASSWORD=<replace_with_local_postgres_password>
POSTGRES_DB=rag_app
DATABASE_URL=postgresql+asyncpg://rag_app:<replace_with_local_postgres_password>@postgres:5432/rag_app
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<replace_with_minio_access_key>
MINIO_SECRET_KEY=<replace_with_minio_secret_key>
MINIO_BUCKET=documents
MINIO_DOCUMENT_PREFIX=raw-documents
UPLOAD_MAX_BYTES=26214400
INGESTION_QUEUE_NAME=ingestion
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=fake-embedding
EMBEDDING_DIM=8
EMBEDDING_TIMEOUT_SECONDS=10
EMBEDDING_RETRY_BUDGET=2
EMBEDDING_QUEUE_NAME=embedding
VECTOR_STORE_TYPE=pgvector
VECTOR_INDEX_DIM=8
VECTOR_DISTANCE_METRIC=cosine
PGVECTOR_INDEX_TYPE=hnsw
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
WORKER_QUEUE_NAME=ingestion
READINESS_TIMEOUT_SECONDS=2
LLM_PROVIDER=fake
LLM_MODEL=fake-llm
LLM_TIMEOUT_SECONDS=10
LLM_RETRY_BUDGET=2
LLM_FAKE_RESPONSE_TEXT=Fake LLM response.
OPENAI_API_KEY=<replace_with_secret>
QWEN_API_KEY=<replace_with_secret>
DEEPSEEK_API_KEY=<replace_with_secret>
